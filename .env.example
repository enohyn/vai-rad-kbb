# Copy this file to ".env" and fill in real values. Never commit the real .env.
# django-environ reads these (see config/settings.py).

# Django secret key (generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=replace-me-with-a-50-char-random-string

# Run in debug mode locally only. Set False in production.
DEBUG=True

# Comma-separated or space-separated list (environ handles both). Include the deployed frontend URL in prod.
# On PythonAnywhere set this to your domain, e.g. <username>.pythonanywhere.com
ALLOWED_HOSTS=*

# Trusted origins for CSRF-protected requests. Use scheme://host, e.g. https://<username>.pythonanywhere.com
CSRF_TRUSTED_ORIGINS=*

# Origins allowed to make cross-origin requests (the Next.js app).
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Database URL. sqlite for dev; e.g. postgres://user:pass@host:5432/dbname in prod.
DATABASE_URL=sqlite:///db.sqlite3

# SimpleJWT token lifetimes (minutes). Short-lived access, long-lived refresh.
ACCESS_TOKEN_MINUTES=15
REFRESH_TOKEN_DAYS=7

# Demo user credentials (used by `python manage.py seed_demo_user`).
# These defaults match the login shown in DEPLOY.md so you can test right away.
DEMO_EMAIL=demo@kanban.test
DEMO_PASSWORD=demoPass123!
DEMO_FIRST_NAME=Demo
DEMO_LAST_NAME=User